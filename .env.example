# Copy to `.env` and fill in real values. `.env` is gitignored.
# These variables flow into both compose.yaml and compose.dev.yaml.

# Must match the public URL users will see (used when constructing the secure
# link and for CORS-sensitive client behaviour).
PUBLIC_BASE_URL=https://securedrop.example.com

# Pick one email backend:
#
# (A) Resend HTTP API (recommended for hosted environments where outbound
#     SMTP ports are filtered). Set RESEND_API_KEY and leave SMTP_URL empty.
#     From address must match a domain verified in your Resend dashboard.
#   RESEND_API_KEY=re_YOUR_KEY_HERE
#
# (B) Plain SMTP via nodemailer. Set SMTP_URL (and leave RESEND_API_KEY empty).
SMTP_URL=smtp://user:pass@smtp.example.com:587
SMTP_FROM="SecureDrop <no-reply@securedrop.example.com>"

# Real Cloudflare Turnstile keys. Generate at
#   https://dash.cloudflare.com/?to=/:account/turnstile
# and list your production hostname in the widget's "Hostname management".
# For local-only testing you can substitute the always-pass test pair:
#   TURNSTILE_SITEKEY=1x00000000000000000000AA
#   TURNSTILE_SECRET=1x0000000000000000000000000000000AA
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

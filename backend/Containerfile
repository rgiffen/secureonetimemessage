FROM docker.io/node:22-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install --omit=optional --no-audit --no-fund --package-lock=false
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM docker.io/node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY package.json ./
RUN npm install --omit=dev --omit=optional --no-audit --no-fund --package-lock=false \
 && npm cache clean --force
COPY --from=build /app/dist ./dist
USER node
EXPOSE 8080
CMD ["node", "dist/server.js"]
